<section class="np-products color-{{ section.settings.color_scheme }}">
  <div class="np-products__heading">
    {% if section.settings.heading != blank %}
      <h2>{{ section.settings.heading | escape }}</h2>
    {% endif %}
    {% if section.settings.link_label != blank %}
      <a href="{{ section.settings.link | default: routes.all_products_collection_url }}">{{ section.settings.link_label | escape }}</a>
    {% endif %}
  </div>

  <div class="np-products__grid">
    {% for block in section.blocks %}
      {% assign chosen_product = block.settings.product %}
      {% assign card_link = block.settings.link %}
      {% if chosen_product != blank %}
        {% assign card_link = chosen_product.url %}
      {% endif %}
      <article class="np-products__card" {{ block.shopify_attributes }}>
        {% if block.settings.image != blank %}
          {% if card_link != blank %}<a class="np-products__media-link" href="{{ card_link }}">{% endif %}
            {{
              block.settings.image
              | image_url: width: 560
              | image_tag: loading: 'lazy', widths: '280, 420, 560', sizes: '(min-width: 990px) 18vw, 90vw'
            }}
          {% if card_link != blank %}</a>{% endif %}
        {% elsif chosen_product != blank and chosen_product.featured_image != blank %}
          <a class="np-products__media-link" href="{{ chosen_product.url }}">
            {{
              chosen_product.featured_image
              | image_url: width: 560
              | image_tag: loading: 'lazy', widths: '280, 420, 560', sizes: '(min-width: 990px) 18vw, 90vw'
            }}
          </a>
        {% else %}
          {% if card_link != blank %}<a class="np-products__media-link" href="{{ card_link }}">{% endif %}
            <span class="np-products__visual np-products__visual--{{ block.settings.visual_style }}"></span>
          {% if card_link != blank %}</a>{% endif %}
        {% endif %}

        <h3>
          {% if card_link != blank %}
            <a href="{{ card_link }}">
              {% if chosen_product != blank %}
                {{ chosen_product.title | escape }}
              {% else %}
                {{ block.settings.title | escape }}
              {% endif %}
            </a>
          {% else %}
            {{ block.settings.title | escape }}
          {% endif %}
        </h3>
        <p>
          {% if chosen_product != blank %}
            {{ chosen_product.price | money }}
          {% else %}
            {{ block.settings.price | escape }}
          {% endif %}
        </p>
        {% if block.settings.review_text != blank %}
          <div class="np-products__reviews">{{ block.settings.review_text | escape }}</div>
        {% endif %}
        {% if block.settings.button_label != blank and card_link != blank %}
          <a class="np-products__button" href="{{ card_link }}">{{ block.settings.button_label | escape }}</a>
        {% endif %}
      </article>
    {% endfor %}
  </div>
</section>

{% stylesheet %}
  .np-products {
    --np-green: #5f734f;
    --np-soft: #f7f6f1;
    color: #202420;
    background: #fff;
  }

  .np-products__heading,
  .np-products__grid {
    width: min(100%, 1500px);
    margin-inline: auto;
  }

  .np-products__heading {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
    padding: 36px clamp(24px, 4vw, 58px) 20px;
  }

  .np-products h2 {
    margin: 0;
    font-size: clamp(1.55rem, 2vw, 2rem);
    letter-spacing: 0;
  }

  .np-products__heading a,
  .np-products__card a:not(.np-products__button) {
    color: inherit;
    text-decoration: none;
  }

  .np-products__heading a {
    color: var(--np-green);
    font-weight: 800;
  }

  .np-products__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 28px;
    padding: 0 clamp(24px, 4vw, 58px) 58px;
  }

  .np-products__card {
    min-width: 0;
  }

  .np-products__media-link,
  .np-products__card img,
  .np-products__visual {
    display: block;
    width: 100%;
  }

  .np-products__card img,
  .np-products__visual {
    aspect-ratio: 1;
    border-radius: 8px;
    background: var(--np-soft);
    overflow: hidden;
    object-fit: cover;
    box-shadow: inset 0 0 0 1px #efede7, 0 10px 22px rgb(54 46 36 / 6%);
  }

  .np-products h3 {
    margin: 16px 0 8px;
    font-size: clamp(1rem, 1.2vw, 1.2rem);
    line-height: 1.25;
    letter-spacing: 0;
  }

  .np-products p {
    margin: 0 0 10px;
    font-size: 1.2rem;
    font-weight: 900;
  }

  .np-products__reviews {
    color: #9b7428;
    font-size: .92rem;
    font-weight: 800;
  }

  .np-products__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 42px;
    margin-top: 14px;
    padding: 0 18px;
    border: 1px solid var(--np-green);
    border-radius: 8px;
    color: var(--np-green);
    font-weight: 800;
    text-decoration: none;
    transition: background-color .18s ease, color .18s ease;
  }

  .np-products__button:hover {
    color: #fff;
    background: var(--np-green);
  }

  .np-products__visual {
    position: relative;
  }

  .np-products__visual::before,
  .np-products__visual::after {
    content: "";
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
  }

  .np-products__visual--roller::before {
    width: 56%;
    height: 28%;
    border: 2px solid #cbc3b8;
    border-radius: 999px;
    background: linear-gradient(#fff, #e0d9cf);
  }

  .np-products__visual--spray::before,
  .np-products__visual--home::before {
    width: 31%;
    height: 62%;
    border: 2px solid #d1c9bd;
    border-radius: 12px;
    background: linear-gradient(#fff 0 18%, #d9e4dc 19% 36%, #efe8dc 37%);
  }

  .np-products__visual--wipes::before {
    width: 60%;
    height: 40%;
    border: 2px solid #e0d9ce;
    border-radius: 10px;
    background: linear-gradient(90deg, #c8dfcf 0 18%, #f6efe2 19% 81%, #c8dfcf 82%);
  }

  .np-products__visual--bundle::before {
    width: 60%;
    height: 58%;
    background:
      linear-gradient(90deg, #f7f3eb 0 28%, transparent 29%),
      linear-gradient(90deg, transparent 34%, #dae5dc 35% 58%, transparent 59%),
      linear-gradient(90deg, transparent 63%, #efe6d9 64% 100%);
  }

  @media screen and (max-width: 1080px) {
    .np-products__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media screen and (max-width: 640px) {
    .np-products__heading {
      padding-inline: 20px;
    }

    .np-products__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 20px;
      padding-inline: 20px;
    }

    .np-products__button {
      width: 100%;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "NeatPet products",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Best Sellers"
    },
    {
      "type": "text",
      "id": "link_label",
      "label": "Link label",
      "default": "View All"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link"
    }
  ],
  "blocks": [
    {
      "type": "product_card",
      "name": "Product card",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Custom image"
        },
        {
          "type": "select",
          "id": "visual_style",
          "label": "Fallback visual",
          "options": [
            { "value": "roller", "label": "Roller" },
            { "value": "spray", "label": "Spray" },
            { "value": "wipes", "label": "Wipes" },
            { "value": "home", "label": "Home" },
            { "value": "bundle", "label": "Bundle" }
          ],
          "default": "roller"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Fallback title",
          "default": "Pet Hair Remover Roller"
        },
        {
          "type": "text",
          "id": "price",
          "label": "Fallback price",
          "default": "$16.99"
        },
        {
          "type": "text",
          "id": "review_text",
          "label": "Review text",
          "default": "5 stars (1,234)"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Fallback link"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label",
          "default": "Shop now"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "NeatPet products",
      "blocks": [
        { "type": "product_card", "settings": { "visual_style": "roller", "title": "Pet Hair Remover Roller", "price": "$16.99", "review_text": "5 stars (1,234)", "button_label": "Shop now" } },
        { "type": "product_card", "settings": { "visual_style": "spray", "title": "Pet Odor Eliminator Spray", "price": "$15.99", "review_text": "5 stars (987)", "button_label": "Shop now" } },
        { "type": "product_card", "settings": { "visual_style": "wipes", "title": "Multi-Surface Pet Wipes", "price": "$12.99", "review_text": "5 stars (856)", "button_label": "Shop now" } },
        { "type": "product_card", "settings": { "visual_style": "home", "title": "Pet Stain & Odor Cleaner", "price": "$17.99", "review_text": "5 stars (765)", "button_label": "Shop now" } },
        { "type": "product_card", "settings": { "visual_style": "bundle", "title": "Neat Home Bundle", "price": "$49.99", "review_text": "5 stars (1,122)", "button_label": "Shop bundle" } }
      ]
    }
  ]
}
{% endschema %}
