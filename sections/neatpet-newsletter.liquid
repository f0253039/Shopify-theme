<section class="np-newsletter color-{{ section.settings.color_scheme }}">
  <div class="np-newsletter__inner">
    <div class="np-newsletter__copy">
      {% if section.settings.heading != blank %}
        <h2>{{ section.settings.heading | escape }}</h2>
      {% endif %}
      {% if section.settings.text != blank %}
        <p>{{ section.settings.text | escape }}</p>
      {% endif %}
    </div>

    {% form 'customer', class: 'np-newsletter__form' %}
      <input type="hidden" name="contact[tags]" value="newsletter">
      <label class="visually-hidden" for="NeatPetNewsletter-{{ section.id }}">Email</label>
      <input id="NeatPetNewsletter-{{ section.id }}" type="email" name="contact[email]" placeholder="{{ section.settings.placeholder | escape }}" required>
      <button type="submit">{{ section.settings.button_label | escape }}</button>
      {% if form.posted_successfully? %}
        <div class="np-newsletter__message np-newsletter__message--success" tabindex="-1">
          {{ section.settings.success_message | escape }}
        </div>
      {% elsif form.errors %}
        <div class="np-newsletter__message np-newsletter__message--error" tabindex="-1">
          {{ form.errors | default_errors }}
        </div>
      {% endif %}
    {% endform %}

    {% if section.settings.image != blank %}
      {{
        section.settings.image
        | image_url: width: 320
        | image_tag: loading: 'lazy', widths: '160, 240, 320', class: 'np-newsletter__image'
      }}
    {% endif %}
  </div>
</section>

{% stylesheet %}
  .np-newsletter {
    --np-green: #5f734f;
    --np-deep: #173022;
    background: #fff;
  }

  .np-newsletter__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    position: relative;
    width: min(100%, 1500px);
    margin: 0 auto 58px;
    padding: clamp(28px, 4vw, 46px);
    color: #fff;
    background: var(--np-deep);
    overflow: hidden;
  }

  .np-newsletter__copy {
    position: relative;
    z-index: 1;
  }

  .np-newsletter h2,
  .np-newsletter p {
    margin: 0;
    letter-spacing: 0;
  }

  .np-newsletter p {
    margin-top: 8px;
    color: rgb(255 255 255 / 72%);
  }

  .np-newsletter__form {
    display: flex;
    flex-wrap: wrap;
    min-width: min(100%, 470px);
    position: relative;
    z-index: 1;
  }

  .np-newsletter__form input,
  .np-newsletter__form button {
    min-height: 54px;
    border: 0;
  }

  .np-newsletter__form input {
    flex: 1;
    min-width: 0;
    padding: 0 18px;
  }

  .np-newsletter__form button {
    padding: 0 24px;
    color: #fff;
    background: var(--np-green);
    font-weight: 800;
  }

  .np-newsletter__message {
    flex: 0 0 100%;
    margin: 10px 0 0;
    font-size: .9rem;
    line-height: 1.4;
  }

  .np-newsletter__message--success {
    color: #dcebd6;
  }

  .np-newsletter__message--error {
    color: #ffd7d0;
  }

  .np-newsletter__image {
    position: absolute;
    right: 18px;
    bottom: -28px;
    width: 140px;
    height: 140px;
    border-radius: 50%;
    object-fit: cover;
    opacity: .28;
  }

  @media screen and (max-width: 1080px) {
    .np-newsletter__inner {
      flex-wrap: wrap;
    }
  }

  @media screen and (max-width: 640px) {
    .np-newsletter__inner {
      margin-inline: 20px;
      padding: 28px 20px;
    }

    .np-newsletter__form {
      flex-direction: column;
      align-items: stretch;
    }

    .np-newsletter__form input,
    .np-newsletter__form button {
      width: 100%;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "NeatPet newsletter",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Join the NeatPet Family"
    },
    {
      "type": "text",
      "id": "text",
      "label": "Text",
      "default": "Get tips, exclusive deals, and pet care advice."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Decorative image"
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Email placeholder",
      "default": "Enter your email"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Subscribe"
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "Success message",
      "default": "Thanks for joining the NeatPet family."
    }
  ],
  "presets": [
    {
      "name": "NeatPet newsletter"
    }
  ]
}
{% endschema %}
