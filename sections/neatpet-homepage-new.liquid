<section class="np-home color-{{ section.settings.color_scheme }}" aria-label="{{ section.settings.accessibility_label | escape }}">
  <div class="np-home__hero">
    <div class="np-home__hero-copy">
      {% if section.settings.eyebrow != blank %}
        <p class="np-home__eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {% endif %}
      {% if section.settings.heading != blank %}
        <h1>{{ section.settings.heading | escape }}</h1>
      {% endif %}
      {% if section.settings.subheading != blank %}
        <div class="np-home__subheading">{{ section.settings.subheading }}</div>
      {% endif %}
      <div class="np-home__actions">
        {% if section.settings.primary_label != blank %}
          <a class="np-home__button np-home__button--primary" href="{{ section.settings.primary_link | default: routes.all_products_collection_url }}">
            {{ section.settings.primary_label | escape }}
          </a>
        {% endif %}
        {% if section.settings.secondary_label != blank %}
          <a class="np-home__button np-home__button--secondary" href="{{ section.settings.secondary_link | default: '/collections' }}">
            {{ section.settings.secondary_label | escape }}
          </a>
        {% endif %}
      </div>
    </div>

    <div class="np-home__hero-art" aria-hidden="true">
      {% if section.settings.hero_image != blank %}
        {{
          section.settings.hero_image
          | image_url: width: 1100
          | image_tag:
            loading: 'eager',
            widths: '440, 660, 880, 1100',
            sizes: '(min-width: 990px) 52vw, 100vw',
            class: 'np-home__hero-image'
        }}
      {% else %}
        <div class="np-home__room">
          <span class="np-home__plant"></span>
          <span class="np-home__sofa"></span>
          <span class="np-home__pet np-home__pet--cat"></span>
          <span class="np-home__pet np-home__pet--dog"></span>
          <span class="np-home__product np-home__product--roller"></span>
          <span class="np-home__product np-home__product--spray"></span>
        </div>
      {% endif %}
    </div>
  </div>

  {% assign benefit_blocks = section.blocks | where: 'type', 'benefit' %}
  {% if benefit_blocks.size > 0 %}
    <div class="np-home__benefits" aria-label="{{ 'Store benefits' | escape }}">
      {% for block in benefit_blocks %}
        <div class="np-home__benefit" {{ block.shopify_attributes }}>
          <span class="np-home__benefit-icon" aria-hidden="true">{{ block.settings.icon | escape }}</span>
          <div>
            {% if block.settings.title != blank %}
              <strong>{{ block.settings.title | escape }}</strong>
            {% endif %}
            {% if block.settings.text != blank %}
              <span>{{ block.settings.text | escape }}</span>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>
  {% endif %}

  {% assign category_blocks = section.blocks | where: 'type', 'category' %}
  {% if category_blocks.size > 0 %}
    <div class="np-home__heading-row">
      <h2>{{ section.settings.category_heading | escape }}</h2>
      {% if section.settings.category_link_label != blank %}
        <a href="{{ section.settings.category_link | default: '/collections' }}">{{ section.settings.category_link_label | escape }}</a>
      {% endif %}
    </div>
    <div class="np-home__tile-grid np-home__tile-grid--categories">
      {% for block in category_blocks %}
        <a class="np-home__tile" href="{{ block.settings.link | default: '/collections' }}" {{ block.shopify_attributes }}>
          {% if block.settings.image != blank %}
            {{
              block.settings.image
              | image_url: width: 520
              | image_tag: loading: 'lazy', widths: '260, 390, 520', sizes: '(min-width: 990px) 18vw, 90vw'
            }}
          {% else %}
            <span class="np-home__visual np-home__visual--{{ block.settings.visual_style }}"></span>
          {% endif %}
          <strong>{{ block.settings.title | escape }}</strong>
          {% if block.settings.text != blank %}
            <em>{{ block.settings.text | escape }}</em>
          {% endif %}
        </a>
      {% endfor %}
    </div>
  {% endif %}

  {% assign product_blocks = section.blocks | where: 'type', 'product_card' %}
  {% if product_blocks.size > 0 %}
    <div class="np-home__heading-row">
      <h2>{{ section.settings.products_heading | escape }}</h2>
      {% if section.settings.products_link_label != blank %}
        <a href="{{ section.settings.products_link | default: routes.all_products_collection_url }}">{{ section.settings.products_link_label | escape }}</a>
      {% endif %}
    </div>
    <div class="np-home__tile-grid np-home__tile-grid--products">
      {% for block in product_blocks %}
        {% assign chosen_product = block.settings.product %}
        <article class="np-home__product-card" {{ block.shopify_attributes }}>
          {% if chosen_product != blank and chosen_product.featured_image != blank %}
            <a href="{{ chosen_product.url }}">
              {{
                chosen_product.featured_image
                | image_url: width: 560
                | image_tag: loading: 'lazy', widths: '280, 420, 560', sizes: '(min-width: 990px) 18vw, 90vw'
              }}
            </a>
          {% else %}
            <span class="np-home__visual np-home__visual--{{ block.settings.visual_style }}"></span>
          {% endif %}
          <h3>
            {% if chosen_product != blank %}
              <a href="{{ chosen_product.url }}">{{ chosen_product.title | escape }}</a>
            {% else %}
              {{ block.settings.title | escape }}
            {% endif %}
          </h3>
          <p>
            {% if chosen_product != blank %}
              {{ chosen_product.price | money }}
            {% else %}
              {{ block.settings.price | escape }}
            {% endif %}
          </p>
          {% if block.settings.review_text != blank %}
            <div class="np-home__stars">{{ block.settings.review_text | escape }}</div>
          {% endif %}
        </article>
      {% endfor %}
    </div>
  {% endif %}

  <div class="np-home__story">
    <div>
      {% if section.settings.story_heading != blank %}
        <h2>{{ section.settings.story_heading | escape }}</h2>
      {% endif %}
      {% if section.settings.story_text != blank %}
        <div>{{ section.settings.story_text }}</div>
      {% endif %}
      {% if section.settings.story_button_label != blank %}
        <a class="np-home__button np-home__button--primary" href="{{ section.settings.story_button_link }}">{{ section.settings.story_button_label | escape }}</a>
      {% endif %}
    </div>
    <div class="np-home__story-media" aria-hidden="true">
      {% if section.settings.story_image != blank %}
        {{
          section.settings.story_image
          | image_url: width: 760
          | image_tag: loading: 'lazy', widths: '380, 570, 760', sizes: '(min-width: 990px) 38vw, 90vw'
        }}
      {% else %}
        <span class="np-home__pet np-home__pet--puppy"></span>
      {% endif %}
    </div>
  </div>

  {% assign service_blocks = section.blocks | where: 'type', 'service' %}
  {% if service_blocks.size > 0 %}
    <div class="np-home__services">
      {% for block in service_blocks %}
        <div {{ block.shopify_attributes }}>
          <strong>{{ block.settings.title | escape }}</strong>
          <span>{{ block.settings.text | escape }}</span>
        </div>
      {% endfor %}
    </div>
  {% endif %}

  {% if section.settings.show_newsletter %}
    <div class="np-home__newsletter">
      <div>
        <h2>{{ section.settings.newsletter_heading | escape }}</h2>
        <p>{{ section.settings.newsletter_text | escape }}</p>
      </div>
      {% form 'customer', class: 'np-home__signup' %}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <label class="visually-hidden" for="NeatPetNewsletter-{{ section.id }}">Email</label>
        <input id="NeatPetNewsletter-{{ section.id }}" type="email" name="contact[email]" placeholder="{{ section.settings.newsletter_placeholder | escape }}" required>
        <button type="submit">{{ section.settings.newsletter_button | escape }}</button>
      {% endform %}
    </div>
  {% endif %}
</section>

{% stylesheet %}
  .np-home {
    --np-green: #5f734f;
    --np-deep: #173022;
    --np-ink: #202420;
    --np-muted: #60665e;
    --np-soft: #f7f6f1;
    --np-border: #e7e3db;
    color: var(--np-ink);
    background: #fff;
  }

  .np-home__hero {
    display: grid;
    grid-template-columns: minmax(320px, .95fr) minmax(420px, 1.15fr);
    min-height: 640px;
    background: linear-gradient(90deg, #fbfbf8 0%, #f8f7f1 44%, #efe7dc 100%);
    border-bottom: 1px solid var(--np-border);
  }

  .np-home__hero-copy {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: clamp(48px, 7vw, 104px) clamp(24px, 6vw, 84px);
  }

  .np-home__eyebrow {
    margin: 0 0 16px;
    color: var(--np-green);
    font-weight: 800;
    text-transform: uppercase;
    font-size: .86rem;
    letter-spacing: .08em;
  }

  .np-home h1,
  .np-home h2,
  .np-home h3,
  .np-home p {
    letter-spacing: 0;
  }

  .np-home h1 {
    max-width: 760px;
    margin: 0;
    color: var(--np-deep);
    font-size: clamp(3rem, 5.8vw, 6rem);
    line-height: 1.06;
  }

  .np-home__subheading {
    max-width: 560px;
    margin-top: 26px;
    color: #41463f;
    font-size: clamp(1.08rem, 1.45vw, 1.45rem);
    line-height: 1.55;
    font-weight: 600;
  }

  .np-home__subheading p,
  .np-home__story p {
    margin: 0;
  }

  .np-home__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 18px;
    margin-top: 40px;
  }

  .np-home__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 58px;
    padding: 0 32px;
    border-radius: 8px;
    font-weight: 800;
    text-decoration: none;
  }

  .np-home__button--primary {
    color: #fff;
    background: var(--np-green);
    box-shadow: 0 10px 22px rgb(55 69 44 / 18%);
  }

  .np-home__button--secondary {
    color: var(--np-ink);
    background: #fff;
    border: 2px solid #d8d7d1;
  }

  .np-home__hero-art {
    min-height: 640px;
    position: relative;
    overflow: hidden;
  }

  .np-home__hero-image,
  .np-home__story-media img,
  .np-home__tile img,
  .np-home__product-card img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .np-home__room {
    position: absolute;
    inset: 0;
  }

  .np-home__sofa {
    position: absolute;
    inset: 82px 0 auto 23%;
    height: 220px;
    border-radius: 44px 0 0 44px;
    background: linear-gradient(135deg, #ded8cf, #f5f0e8 64%, #d8d0c5);
    box-shadow: inset 0 -22px 40px rgb(72 64 55 / 14%);
  }

  .np-home__plant {
    position: absolute;
    left: 13%;
    top: 28px;
    width: 150px;
    height: 280px;
    background:
      radial-gradient(ellipse at 35% 20%, #779259 0 18%, transparent 19%),
      radial-gradient(ellipse at 65% 28%, #6e884f 0 18%, transparent 19%),
      radial-gradient(ellipse at 28% 48%, #809a61 0 18%, transparent 19%),
      radial-gradient(ellipse at 72% 58%, #6d854f 0 20%, transparent 21%),
      linear-gradient(100deg, transparent 48%, #708756 49% 55%, transparent 56%);
  }

  .np-home__pet,
  .np-home__product,
  .np-home__visual {
    display: block;
    position: relative;
  }

  .np-home__pet {
    position: absolute;
    bottom: 58px;
    box-shadow: 0 22px 35px rgb(81 63 41 / 17%);
  }

  .np-home__pet::before,
  .np-home__pet::after,
  .np-home__product::before,
  .np-home__visual::before,
  .np-home__visual::after {
    content: "";
    position: absolute;
  }

  .np-home__pet--dog {
    right: 25%;
    width: 250px;
    height: 305px;
    z-index: 3;
    border-radius: 48% 48% 38% 38%;
    background:
      radial-gradient(circle at 39% 38%, #1d1b18 0 6px, transparent 7px),
      radial-gradient(circle at 61% 38%, #1d1b18 0 6px, transparent 7px),
      radial-gradient(circle at 50% 53%, #3d2b20 0 15px, transparent 16px),
      linear-gradient(135deg, #e5bd76, #c98a45);
  }

  .np-home__pet--cat {
    left: 9%;
    width: 170px;
    height: 210px;
    z-index: 2;
    border-radius: 45% 45% 35% 35%;
    background:
      radial-gradient(circle at 38% 44%, #1c1c18 0 5px, transparent 6px),
      radial-gradient(circle at 62% 44%, #1c1c18 0 5px, transparent 6px),
      repeating-linear-gradient(110deg, #b18d68 0 14px, #d5c2a6 15px 25px);
  }

  .np-home__pet--puppy {
    left: 50%;
    bottom: 34px;
    width: 240px;
    height: 270px;
    transform: translateX(-50%);
    border-radius: 48% 48% 38% 38%;
    background:
      radial-gradient(circle at 38% 39%, #1d1b18 0 7px, transparent 8px),
      radial-gradient(circle at 62% 39%, #1d1b18 0 7px, transparent 8px),
      radial-gradient(circle at 50% 55%, #4e3020 0 17px, transparent 18px),
      linear-gradient(135deg, #e0b46e, #bd7d42);
  }

  .np-home__product {
    position: absolute;
    bottom: 48px;
    z-index: 4;
  }

  .np-home__product--roller {
    right: 13%;
    width: 160px;
    height: 76px;
    border-radius: 38px;
    background: linear-gradient(#fff, #e7e2d9);
    border: 3px solid #d0c9bd;
  }

  .np-home__product--spray {
    right: 4%;
    width: 82px;
    height: 220px;
    border-radius: 18px 18px 12px 12px;
    background: linear-gradient(#f9faf7 0 18%, #d8e0d9 19% 34%, #f2eadf 35%);
    border: 2px solid #d7d0c5;
  }

  .np-home__benefits,
  .np-home__tile-grid,
  .np-home__heading-row,
  .np-home__story,
  .np-home__services,
  .np-home__newsletter {
    width: min(100%, 1500px);
    margin-inline: auto;
  }

  .np-home__benefits {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
    padding: 30px clamp(24px, 4vw, 58px);
    border-bottom: 1px solid var(--np-border);
  }

  .np-home__benefit {
    display: flex;
    align-items: center;
    gap: 16px;
    min-width: 0;
  }

  .np-home__benefit-icon {
    flex: 0 0 42px;
    display: grid;
    place-items: center;
    width: 42px;
    height: 42px;
    border-radius: 50%;
    color: #fff;
    background: var(--np-green);
    font-weight: 900;
  }

  .np-home__benefit strong,
  .np-home__benefit span,
  .np-home__services strong,
  .np-home__services span {
    display: block;
  }

  .np-home__benefit strong {
    color: #2b302a;
    font-size: 1.06rem;
  }

  .np-home__benefit span,
  .np-home__tile em,
  .np-home__services span {
    margin-top: 4px;
    color: var(--np-muted);
    font-size: .92rem;
    font-style: normal;
  }

  .np-home__heading-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
    padding: 36px clamp(24px, 4vw, 58px) 20px;
  }

  .np-home__heading-row h2 {
    margin: 0;
    font-size: clamp(1.55rem, 2vw, 2rem);
  }

  .np-home__heading-row a,
  .np-home__product-card a {
    color: inherit;
    text-decoration: none;
  }

  .np-home__heading-row a {
    color: var(--np-green);
    font-weight: 800;
  }

  .np-home__tile-grid {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 28px;
    padding-inline: clamp(24px, 4vw, 58px);
  }

  .np-home__tile,
  .np-home__product-card {
    min-width: 0;
  }

  .np-home__tile {
    display: block;
    color: #2b302a;
    text-align: center;
    text-decoration: none;
  }

  .np-home__tile img,
  .np-home__product-card img,
  .np-home__visual {
    aspect-ratio: 1;
    border-radius: 8px;
    background: var(--np-soft);
    overflow: hidden;
    box-shadow: inset 0 0 0 1px #efede7, 0 10px 22px rgb(54 46 36 / 6%);
  }

  .np-home__tile strong,
  .np-home__tile em {
    display: block;
  }

  .np-home__tile strong {
    margin-top: 15px;
    font-size: 1.06rem;
  }

  .np-home__visual::before,
  .np-home__visual::after {
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
  }

  .np-home__visual--roller::before {
    width: 56%;
    height: 28%;
    border-radius: 999px;
    background: linear-gradient(#fff, #e0d9cf);
    border: 2px solid #cbc3b8;
  }

  .np-home__visual--spray::before,
  .np-home__visual--home::before {
    width: 31%;
    height: 62%;
    border-radius: 12px;
    background: linear-gradient(#fff 0 18%, #d9e4dc 19% 36%, #efe8dc 37%);
    border: 2px solid #d1c9bd;
  }

  .np-home__visual--wipes::before {
    width: 60%;
    height: 40%;
    border-radius: 10px;
    background: linear-gradient(90deg, #c8dfcf 0 18%, #f6efe2 19% 81%, #c8dfcf 82%);
    border: 2px solid #e0d9ce;
  }

  .np-home__visual--bundle::before {
    width: 60%;
    height: 58%;
    background:
      linear-gradient(90deg, #f7f3eb 0 28%, transparent 29%),
      linear-gradient(90deg, transparent 34%, #dae5dc 35% 58%, transparent 59%),
      linear-gradient(90deg, transparent 63%, #efe6d9 64% 100%);
  }

  .np-home__tile-grid--products {
    padding-bottom: 58px;
  }

  .np-home__product-card h3 {
    margin: 16px 0 8px;
    font-size: clamp(1rem, 1.2vw, 1.2rem);
    line-height: 1.25;
  }

  .np-home__product-card p {
    margin: 0 0 10px;
    font-size: 1.2rem;
    font-weight: 900;
  }

  .np-home__stars {
    color: #d9a23b;
    font-weight: 800;
    font-size: .92rem;
  }

  .np-home__story {
    display: grid;
    grid-template-columns: minmax(320px, .9fr) minmax(320px, 1fr);
    gap: clamp(28px, 5vw, 70px);
    align-items: center;
    margin-block: 18px 48px;
    padding: clamp(32px, 5vw, 64px);
    background: #f3f6ee;
  }

  .np-home__story h2 {
    margin: 0 0 18px;
    color: var(--np-deep);
    font-size: clamp(2rem, 3.2vw, 3.8rem);
    line-height: 1.1;
  }

  .np-home__story .np-home__button {
    margin-top: 28px;
  }

  .np-home__story-media {
    min-height: 360px;
    position: relative;
    overflow: hidden;
    border-radius: 8px;
    background: linear-gradient(135deg, #efe8dc, #dce8dd);
  }

  .np-home__services {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    margin-bottom: 48px;
    background: var(--np-border);
    border: 1px solid var(--np-border);
  }

  .np-home__services div {
    padding: 24px;
    background: #fff;
  }

  .np-home__services strong {
    color: #2b302a;
  }

  .np-home__newsletter {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    margin-bottom: 58px;
    padding: clamp(28px, 4vw, 46px);
    color: #fff;
    background: var(--np-deep);
  }

  .np-home__newsletter h2,
  .np-home__newsletter p {
    margin: 0;
  }

  .np-home__newsletter p {
    margin-top: 8px;
    color: rgb(255 255 255 / 72%);
  }

  .np-home__signup {
    display: flex;
    min-width: min(100%, 470px);
  }

  .np-home__signup input,
  .np-home__signup button {
    min-height: 54px;
    border: 0;
  }

  .np-home__signup input {
    flex: 1;
    min-width: 0;
    padding: 0 18px;
  }

  .np-home__signup button {
    padding: 0 24px;
    color: #fff;
    background: var(--np-green);
    font-weight: 800;
  }

  @media screen and (max-width: 1080px) {
    .np-home__hero,
    .np-home__story {
      grid-template-columns: 1fr;
    }

    .np-home__benefits,
    .np-home__tile-grid,
    .np-home__services {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .np-home__newsletter {
      flex-wrap: wrap;
    }
  }

  @media screen and (max-width: 640px) {
    .np-home__hero {
      min-height: auto;
    }

    .np-home__hero-copy {
      padding: 42px 20px;
    }

    .np-home__hero-art {
      min-height: 360px;
    }

    .np-home__actions,
    .np-home__signup {
      flex-direction: column;
      align-items: stretch;
    }

    .np-home__button,
    .np-home__signup button,
    .np-home__signup input {
      width: 100%;
    }

    .np-home__benefits,
    .np-home__tile-grid,
    .np-home__services {
      grid-template-columns: 1fr;
      gap: 20px;
      padding-inline: 20px;
    }

    .np-home__heading-row {
      padding-inline: 20px;
    }

    .np-home__story,
    .np-home__newsletter {
      margin-inline: 20px;
      padding: 28px 20px;
    }

    .np-home__services {
      display: grid;
      gap: 1px;
      padding-inline: 0;
      margin-inline: 20px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "NeatPet homepage new",
  "settings": [
    {
      "type": "text",
      "id": "accessibility_label",
      "label": "Accessibility label",
      "default": "NeatPet homepage"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Pet-safe home care"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "A Cleaner Home Makes Happier Pets"
    },
    {
      "type": "richtext",
      "id": "subheading",
      "label": "Subheading",
      "default": "<p>Smart cleaning solutions that keep your home fresh, tidy, and pet-friendly.</p>"
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "Primary button label",
      "default": "Shop All Products"
