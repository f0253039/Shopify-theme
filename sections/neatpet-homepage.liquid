<section class="neatpet-home" aria-label="NeatPet homepage">
  <div class="neatpet-shell">
    <div class="neatpet-hero">
      <div class="neatpet-hero__copy">
        <h1>A Cleaner Home Makes Happier Pets</h1>
        <p>Smart cleaning solutions that keep your home fresh, tidy, and pet-friendly.</p>
        <div class="neatpet-hero__actions">
          <a class="neatpet-button neatpet-button--primary" href="{{ routes.all_products_collection_url }}">Shop All Products</a>
          <a class="neatpet-button neatpet-button--secondary" href="/collections">Explore Bundles</a>
        </div>
      </div>
      <div class="neatpet-hero__scene" aria-hidden="true">
        <div class="neatpet-plant"></div>
        <div class="neatpet-sofa"></div>
        <div class="neatpet-pet neatpet-pet--cat">
          <span></span>
        </div>
        <div class="neatpet-pet neatpet-pet--dog">
          <span></span>
        </div>
        <div class="neatpet-product neatpet-product--roller"></div>
        <div class="neatpet-product neatpet-product--spray"></div>
        <div class="neatpet-product neatpet-product--jar"></div>
      </div>
    </div>

    <div class="neatpet-benefits" aria-label="Store benefits">
      <div class="neatpet-benefit">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M7.8 8.7a3.3 3.3 0 1 1 0-6.6 3.3 3.3 0 0 1 0 6.6Zm8.4 0a3.3 3.3 0 1 1 0-6.6 3.3 3.3 0 0 1 0 6.6ZM5.8 19.8a3.7 3.7 0 1 1 0-7.4 3.7 3.7 0 0 1 0 7.4Zm12.4 0a3.7 3.7 0 1 1 0-7.4 3.7 3.7 0 0 1 0 7.4Zm-6.2 2.1c-2.4 0-4.4-1.5-4.4-3.4 0-2.2 2.3-5.4 4.4-5.4s4.4 3.2 4.4 5.4c0 1.9-2 3.4-4.4 3.4Z"/></svg>
        <div><strong>Pet-Safe Ingredients</strong><span>Safe for pets and family</span></div>
      </div>
      <div class="neatpet-benefit">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2.2 14 8h6.1l-4.9 3.6 1.9 5.9-5.1-3.7-5.1 3.7 1.9-5.9L3.9 8H10l2-5.8Zm0 15.3 2.1 4.3H9.9l2.1-4.3ZM2.2 13.1l4.4 1.1-3 3-1.4-4.1Zm19.6 0-1.4 4.1-3-3 4.4-1.1Z"/></svg>
        <div><strong>Powerful Cleaning</strong><span>Tough on mess, gentle at home</span></div>
      </div>
      <div class="neatpet-benefit">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2.4c2.4 3 3.7 5.3 3.7 7a3.7 3.7 0 0 1-7.4 0c0-1.7 1.3-4 3.7-7Zm7.8 12.3c.9 1.2 1.4 2.2 1.4 3.1a2.5 2.5 0 0 1-5 0c0-.9.5-1.9 1.4-3.1l1.1-1.4 1.1 1.4ZM5.3 13.3l1.1 1.4c.9 1.2 1.4 2.2 1.4 3.1a2.5 2.5 0 0 1-5 0c0-.9.5-1.9 1.4-3.1l1.1-1.4ZM3 21h18v1.5H3V21Z"/></svg>
        <div><strong>Odor Elimination</strong><span>Neutralizes odor at the source</span></div>
      </div>
      <div class="neatpet-benefit">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M20.8 3.2c.4 5.6-2.3 9.4-6.8 9.4h-.5c-.4 3.6-2.1 6.4-5.8 8.1l-1-1.9c2.9-1.4 4.2-3.5 4.6-6.4-2.5-.8-4.1-2.9-4.1-5.7 0-1 .2-2 .6-3 4.5-.5 7.1.8 8.5 3.1 1.1-1 2.5-2.1 4.5-3.6ZM4.6 12.2c-1.5 1.3-2.2 2.7-2.2 4.3 2 .1 3.5-.5 4.6-1.8l-2.4-2.5Z"/></svg>
        <div><strong>Eco-Friendly</strong><span>Better for pets, people, planet</span></div>
      </div>
    </div>

    <div class="neatpet-section-heading">
      <h2>Shop by Category</h2>
      <a href="/collections">View All</a>
    </div>
    <div class="neatpet-category-grid">
      <a class="neatpet-category" href="/collections"><span class="neatpet-visual neatpet-visual--roller"></span><strong>Cleaning Tools</strong><em>Keep fur and mess away</em></a>
      <a class="neatpet-category" href="/collections"><span class="neatpet-visual neatpet-visual--spray"></span><strong>Odor Control</strong><em>Eliminate bad smells</em></a>
      <a class="neatpet-category" href="/collections"><span class="neatpet-visual neatpet-visual--wipes"></span><strong>Surface Cleaning</strong><em>Clean every corner</em></a>
      <a class="neatpet-category" href="/collections"><span class="neatpet-visual neatpet-visual--home"></span><strong>Home Care</strong><em>Daily care for a tidy home</em></a>
      <a class="neatpet-category" href="/collections"><span class="neatpet-visual neatpet-visual--bundle"></span><strong>Bundles</strong><em>More care, more value</em></a>
    </div>

    <div class="neatpet-section-heading">
      <h2>Best Sellers</h2>
      <a href="{{ routes.all_products_collection_url }}">View All</a>
    </div>
    <div class="neatpet-product-grid">
      <article class="neatpet-card"><span class="neatpet-visual neatpet-visual--roller"></span><h3>Pet Hair Remover Roller</h3><p>$16.99</p><div class="neatpet-stars">&#9733;&#9733;&#9733;&#9733;&#9733; <span>(1,234)</span></div></article>
      <article class="neatpet-card"><span class="neatpet-visual neatpet-visual--spray"></span><h3>Pet Odor Eliminator Spray</h3><p>$15.99</p><div class="neatpet-stars">&#9733;&#9733;&#9733;&#9733;&#9733; <span>(987)</span></div></article>
      <article class="neatpet-card"><span class="neatpet-visual neatpet-visual--wipes"></span><h3>Multi-Surface Pet Wipes</h3><p>$12.99</p><div class="neatpet-stars">&#9733;&#9733;&#9733;&#9733;&#9733; <span>(856)</span></div></article>
      <article class="neatpet-card"><span class="neatpet-visual neatpet-visual--home"></span><h3>Pet Stain &amp; Odor Cleaner</h3><p>$17.99</p><div class="neatpet-stars">&#9733;&#9733;&#9733;&#9733;&#9733; <span>(765)</span></div></article>
      <article class="neatpet-card"><span class="neatpet-visual neatpet-visual--bundle"></span><h3>Neat Home Bundle</h3><p>$49.99 <s>$59.99</s></p><div class="neatpet-stars">&#9733;&#9733;&#9733;&#9733;&#9733; <span>(1,122)</span></div></article>
    </div>

    <div class="neatpet-story">
      <div>
        <h2>Designed for Pets.<br>Loved by Pet Parents.</h2>
        <p>At NeatPet, we create cleaning solutions that help you enjoy more time with your pets in a clean, fresh home.</p>
        <a class="neatpet-button neatpet-button--primary" href="/pages/about-us">Learn Our Story</a>
      </div>
      <div class="neatpet-story__image" aria-hidden="true">
        <div class="neatpet-pet neatpet-pet--puppy"><span></span></div>
      </div>
    </div>

    <div class="neatpet-service-row">
      <div><strong>Secure Checkout</strong><span>Safe and encrypted payments</span></div>
      <div><strong>Satisfaction Guaranteed</strong><span>Love it or get your money back</span></div>
      <div><strong>Trusted by Pet Parents</strong><span>Thousands of happy homes</span></div>
      <div><strong>Customer Support</strong><span>We're here to help</span></div>
    </div>

    <div class="neatpet-newsletter">
      <div><h2>Join the NeatPet Family</h2><p>Get tips, exclusive deals, and pet care advice.</p></div>
      {% form 'customer', class: 'neatpet-signup' %}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <label class="visually-hidden" for="NeatPetNewsletter">Email</label>
        <input id="NeatPetNewsletter" type="email" name="contact[email]" placeholder="Enter your email" required>
        <button type="submit">Subscribe</button>
      {% endform %}
      <div class="neatpet-social" aria-label="Social links"><span>f</span><span>ig</span><span>tk</span><span>p</span><span>mail</span></div>
      <div class="neatpet-paw" aria-hidden="true"></div>
    </div>
  </div>
</section>

{% stylesheet %}
  .neatpet-home {
    --np-green: #647653;
    --np-deep: #183022;
    --np-soft: #f7f7f3;
    --np-mint: #b9d4bd;
    --np-border: #e7e6df;
    background: #fff;
    color: #202420;
    font-family: var(--font-body--family);
  }

  .neatpet-shell {
    width: min(100%, 1500px);
    margin-inline: auto;
    overflow: hidden;
    background: #fff;
  }

  .neatpet-hero {
    display: grid;
    grid-template-columns: minmax(320px, 0.92fr) minmax(420px, 1.25fr);
    min-height: 620px;
    background: linear-gradient(90deg, #fbfbf8 0%, #f8f8f3 41%, #eee9df 100%);
    border-block-end: 1px solid var(--np-border);
    position: relative;
  }

  .neatpet-hero__copy {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: clamp(52px, 7vw, 104px) clamp(28px, 6vw, 82px);
  }

  .neatpet-hero h1 {
    max-width: 760px;
    margin: 0;
    color: var(--np-deep);
    font-size: clamp(3.1rem, 6vw, 6rem);
    line-height: 1.08;
    letter-spacing: 0;
  }

  .neatpet-hero p {
    max-width: 520px;
    margin: 28px 0 0;
    color: #42443f;
    font-size: clamp(1.1rem, 1.6vw, 1.55rem);
    line-height: 1.55;
    font-weight: 600;
  }

  .neatpet-hero__actions,
  .neatpet-newsletter,
  .neatpet-section-heading,
  .neatpet-service-row,
  .neatpet-benefit {
    display: flex;
    align-items: center;
  }

  .neatpet-hero__actions {
    gap: 20px;
    flex-wrap: wrap;
    margin-top: 42px;
  }

  .neatpet-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 58px;
    padding: 0 34px;
    border-radius: 8px;
    font-weight: 800;
    text-decoration: none;
  }

  .neatpet-button--primary {
    background: var(--np-green);
    color: #fff;
    box-shadow: 0 10px 22px rgb(55 69 44 / 18%);
  }

  .neatpet-button--secondary {
    background: #fff;
    color: #202420;
    border: 2px solid #d9dad6;
  }

  .neatpet-hero__scene {
    position: relative;
    min-height: 620px;
    overflow: hidden;
  }

  .neatpet-sofa {
    position: absolute;
    inset: 72px 0 auto 26%;
    height: 220px;
    border-radius: 44px 0 0 44px;
    background: linear-gradient(135deg, #ded8cf, #f5f0e8 64%, #d8d0c5);
    box-shadow: inset 0 -22px 40px rgb(72 64 55 / 14%);
  }

  .neatpet-sofa::before,
  .neatpet-sofa::after {
    content: "";
    position: absolute;
    top: 46px;
    width: 180px;
    height: 130px;
    border-radius: 30px;
    background: #f4eee6;
    box-shadow: 0 10px 25px rgb(77 64 48 / 10%);
  }

  .neatpet-sofa::before { left: 52px; }
  .neatpet-sofa::after { right: 80px; }

  .neatpet-plant {
    position: absolute;
    left: 15%;
    top: 26px;
    width: 150px;
    height: 280px;
    filter: blur(1px);
    opacity: .8;
  }

  .neatpet-plant::before {
    content: "";
    position: absolute;
    left: 72px;
    top: 40px;
    width: 10px;
    height: 240px;
    background: #708756;
    border-radius: 10px;
    transform: rotate(10deg);
  }

  .neatpet-plant::after {
    content: "";
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 35% 20%, #779259 0 18%, transparent 19%),
      radial-gradient(ellipse at 65% 28%, #6e884f 0 18%, transparent 19%),
      radial-gradient(ellipse at 28% 48%, #809a61 0 18%, transparent 19%),
      radial-gradient(ellipse at 72% 58%, #6d854f 0 20%, transparent 21%),
      radial-gradient(ellipse at 34% 77%, #879d68 0 17%, transparent 18%);
  }

  .neatpet-pet,
  .neatpet-product,
  .neatpet-visual {
    display: block;
    position: relative;
  }

  .neatpet-pet {
    position: absolute;
    bottom: 58px;
    background: linear-gradient(135deg, #e5bd76, #c98a45);
    box-shadow: 0 22px 35px rgb(81 63 41 / 17%);
  }

  .neatpet-pet::before,
  .neatpet-pet::after,
  .neatpet-pet span::before,
  .neatpet-pet span::after {
    content: "";
    position: absolute;
  }

  .neatpet-pet--dog {
    right: 27%;
    width: 250px;
    height: 305px;
    border-radius: 48% 48% 38% 38%;
    z-index: 3;
  }

  .neatpet-pet--dog::before,
  .neatpet-pet--dog::after {
    top: 56px;
    width: 58px;
    height: 118px;
    border-radius: 42px;
    background: #c98a45;
  }

  .neatpet-pet--dog::before { left: -20px; transform: rotate(14deg); }
  .neatpet-pet--dog::after { right: -20px; transform: rotate(-14deg); }

  .neatpet-pet--dog span::before {
    left: 78px;
    top: 112px;
    width: 96px;
    height: 74px;
    border-radius: 50%;
    background: radial-gradient(circle at 33% 25%, #1d1b18 0 6px, transparent 7px), radial-gradient(circle at 68% 25%, #1d1b18 0 6px, transparent 7px), radial-gradient(circle at 50% 56%, #3d2b20 0 15px, transparent 16px), #f2d3a0;
  }

  .neatpet-pet--dog span::after {
    left: 95px;
    top: 186px;
    width: 60px;
    height: 32px;
    border-radius: 0 0 35px 35px;
    background: #a9564a;
  }

  .neatpet-pet--cat {
    left: 9%;
    width: 170px;
    height: 210px;
    border-radius: 45% 45% 35% 35%;
    background: repeating-linear-gradient(110deg, #b18d68 0 14px, #d5c2a6 15px 25px);
    z-index: 2;
  }

  .neatpet-pet--cat::before,
  .neatpet-pet--cat::after {
    top: -22px;
    width: 54px;
    height: 58px;
    background: #a9845e;
    clip-path: polygon(50% 0, 0 100%, 100% 100%);
  }

  .neatpet-pet--cat::before { left: 28px; }
  .neatpet-pet--cat::after { right: 28px; }

  .neatpet-pet--cat span::before {
    left: 45px;
    top: 86px;
    width: 82px;
    height: 56px;
    border-radius: 50%;
    background: radial-gradient(circle at 30% 30%, #1c1c18 0 5px, transparent 6px), radial-gradient(circle at 70% 30%, #1c1c18 0 5px, transparent 6px), radial-gradient(circle at 50% 56%, #8d5648 0 10px, transparent 11px), #e9d4bb;
  }

  .neatpet-pet--cat span::after {
    right: -42px;
    bottom: 18px;
    width: 96px;
    height: 38px;
    border: 22px solid #92714d;
    border-left: 0;
    border-radius: 0 60px 60px 0;
  }

  .neatpet-product--roller,
  .neatpet-product--spray,
  .neatpet-product--jar {
    position: absolute;
    bottom: 48px;
    z-index: 4;
  }

  .neatpet-product--roller {
    right: 13%;
    width: 160px;
    height: 76px;
    border-radius: 38px;
    background: linear-gradient(#fff, #e7e2d9);
    border: 3px solid #d0c9bd;
  }

  .neatpet-product--roller::before {
    content: "";
    position: absolute;
    left: 86px;
    bottom: 68px;
    width: 18px;
    height: 160px;
    border-radius: 16px;
    background: #f0ece4;
    transform: rotate(3deg);
  }

  .neatpet-product--spray {
    right: 5.5%;
    width: 82px;
    height: 220px;
    border-radius: 18px 18px 12px 12px;
    background: linear-gradient(#f9faf7 0 18%, #d8e0d9 19% 34%, #f2eadf 35%);
    border: 2px solid #d7d0c5;
  }

  .neatpet-product--spray::before {
    content: "";
    position: absolute;
    right: 4px;
    top: -46px;
    width: 86px;
    height: 52px;
    border-radius: 12px 24px 8px 8px;
    background: #fff;
    box-shadow: inset -22px 0 #e8e3dc;
  }

  .neatpet-product--jar {
    right: 0.8%;
    width: 92px;
    height: 120px;
    border-radius: 12px;
    background: linear-gradient(#f8f4ec, #ded8cf);
    border: 2px solid #d2c9bd;
  }

  .neatpet-benefits {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
    padding: 30px clamp(24px, 4vw, 58px);
    border-block-end: 1px solid var(--np-border);
  }

  .neatpet-benefit {
    gap: 16px;
    min-width: 0;
  }

  .neatpet-benefit svg {
    flex: 0 0 42px;
    width: 42px;
    height: 42px;
    fill: none;
    stroke: var(--np-green);
    stroke-width: 1.8;
  }

  .neatpet-benefit strong,
  .neatpet-benefit span {
    display: block;
  }

  .neatpet-benefit strong {
    color: #2b302a;
    font-size: 1.08rem;
  }

  .neatpet-benefit span {
    margin-top: 4px;
    color: #666861;
    font-size: .92rem;
  }

  .neatpet-section-heading {
    justify-content: space-between;
    gap: 18px;
    padding: 34px clamp(24px, 4vw, 58px) 20px;
  }

  .neatpet-section-heading h2 {
    margin: 0;
    font-size: clamp(1.55rem, 2vw, 2rem);
    letter-spacing: 0;
  }

  .neatpet-section-heading a {
    color: var(--np-green);
    font-weight: 800;
    text-decoration: none;
  }

  .neatpet-category-grid,
  .neatpet-product-grid {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 28px;
    padding-inline: clamp(24px, 4vw, 58px);
  }

  .neatpet-category,
  .neatpet-card {
    min-width: 0;
  }

  .neatpet-category {
    display: block;
    text-align: center;
    text-decoration: none;
    color: #2b302a;
  }

  .neatpet-category strong,
  .neatpet-category em {
    display: block;
  }

  .neatpet-category strong {
    margin-top: 15px;
    font-size: 1.06rem;
  }

  .neatpet-category em {
    margin-top: 5px;
    color: #666861;
    font-style: normal;
    font-size: .92rem;
  }

  .neatpet-visual {
    aspect-ratio: 1;
    border-radius: 8px;
    background: #f7f5f1;
    overflow: hidden;
    box-shadow: inset 0 0 0 1px #efede7, 0 10px 22px rgb(54 46 36 / 6%);
  }

  .neatpet-visual::before,
  .neatpet-visual::after {
    content: "";
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
  }

  .neatpet-visual--roller::before {
    width: 56%;
    height: 28%;
    border-radius: 999px;
    background: linear-gradient(#fff, #e0d9cf);
    border: 2px solid #cbc3b8;
  }

  .neatpet-visual--roller::after {
    width: 8%;
    height: 58%;
    top: 36%;
    border-radius: 999px;
    background: #e7ded2;
    transform: translate(-35%, -50%) rotate(18deg);
  }

  .neatpet-visual--spray::before,
  .neatpet-visual--home::before {
    width: 31%;
    height: 62%;
    border-radius: 12px;
    background: linear-gradient(#fff 0 18%, #d9e4dc 19% 36%, #efe8dc 37%);
    border: 2px solid #d1c9bd;
  }

  .neatpet-visual--spray::after,
  .neatpet-visual--home::after {
    width: 38%;
    height: 18%;
    top: 19%;
    border-radius: 8px 16px 6px 6px;
    background: #fff;
    transform: translate(-36%, -50%);
  }

  .neatpet-visual--wipes::before {
    width: 60%;
    height: 40%;
    border-radius: 10px;
    background: linear-gradient(90deg, #c8dfcf 0 18%, #f6efe2 19% 81%, #c8dfcf 82%);
    border: 2px solid #e0d9ce;
  }

  .neatpet-visual--wipes::after {
    width: 30%;
    height: 22%;
    top: 35%;
    border-radius: 60% 40% 60% 30%;
    background: #fff;
    box-shadow: 0 4px 10px rgb(95 85 70 / 10%);
  }

  .neatpet-visual--bundle::before {
    width: 60%;
    height: 58%;
    background:
      radial-gradient(circle at 20% 80%, #e6dfd4 0 19%, transparent 20%),
      linear-gradient(90deg, #f7f3eb 0 28%, transparent 29%),
      linear-gradient(90deg, transparent 34%, #dae5dc 35% 58%, transparent 59%),
      linear-gradient(90deg, transparent 63%, #efe6d9 64% 100%);
  }

  .neatpet-visual--home::after {
    width: 52%;
    height: 12%;
    top: 72%;
    border-radius: 999px;
    background: #dfd6cb;
  }

  .neatpet-product-grid {
    padding-bottom: 58px;
  }

  .neatpet-card h3 {
    margin: 16px 0 8px;
    font-size: clamp(1rem, 1.2vw, 1.2rem);
    line-height: 1.25;
    letter-spacing: 0;
  }

  .neatpet-card p {
    margin: 0 0 12px;
    font-size: 1.22rem;
    font-weight: 900;
  }

  .neatpet-card s {
    color: #8a8880;
    font-weight: 600;
    margin-left: 8px;
  }

  .neatpet-stars {
    color: #ff9318;
    font-weight: 900;
    letter-spacing: 1px;
  }

  .neatpet-stars span {
    color: #6d6d66;
    font-weight: 600;
    letter-spacing: 0;
    margin-left: 6px;
  }

  .neatpet-story {
    display: grid;
    grid-template-columns: .95fr 1.55fr;
    min-height: 290px;
    margin: 0 clamp(24px, 4vw, 58px) 50px;
    border-radius: 8px;
    overflow: hidden;
    background: linear-gradient(90deg, #eef3e7 0%, #f8f5ef 43%, #e7ded2 100%);
  }

  .neatpet-story > div:first-child {
    padding: clamp(28px, 4vw, 54px);
  }

  .neatpet-story h2 {
    margin: 0;
    color: #263124;
    font-size: clamp(1.7rem, 2.8vw, 3.1rem);
    line-height: 1.15;
    letter-spacing: 0;
  }

  .neatpet-story p {
    max-width: 520px;
    margin: 20px 0 28px;
    color: #454941;
    font-size: 1.08rem;
    line-height: 1.55;
    font-weight: 600;
  }

  .neatpet-story__image {
    position: relative;
    overflow: hidden;
  }

  .neatpet-story__image::before {
    content: "";
    position: absolute;
    inset: 64px -40px 0 10%;
    border-radius: 60px 0 0 0;
    background: linear-gradient(135deg, #efe8dd, #cfc5ba);
  }

  .neatpet-pet--puppy {
    right: 28%;
    bottom: 0;
    width: 210px;
    height: 210px;
    border-radius: 45% 45% 32% 32%;
    background: linear-gradient(135deg, #d4a15f, #af6e34);
  }

  .neatpet-pet--puppy span::before {
    left: 60px;
    top: 78px;
    width: 88px;
    height: 66px;
    border-radius: 50%;
    background: radial-gradient(circle at 30% 30%, #1e1915 0 6px, transparent 7px), radial-gradient(circle at 70% 30%, #1e1915 0 6px, transparent 7px), radial-gradient(circle at 50% 58%, #3b2920 0 14px, transparent 15px), #e6c18b;
  }

  .neatpet-service-row {
    justify-content: space-between;
    gap: 20px;
    padding: 28px clamp(24px, 4vw, 58px);
    border-block: 1px solid var(--np-border);
  }

  .neatpet-service-row div {
    position: relative;
    padding-left: 52px;
  }

  .neatpet-service-row div::before {
    content: "";
    position: absolute;
    left: 0;
    top: 2px;
    width: 34px;
    height: 34px;
    border: 2px solid var(--np-green);
    border-radius: 9px;
  }

  .neatpet-service-row strong,
  .neatpet-service-row span {
    display: block;
  }

  .neatpet-service-row strong {
    font-size: 1rem;
  }

  .neatpet-service-row span {
    margin-top: 4px;
    color: #646760;
    font-size: .92rem;
  }

  .neatpet-newsletter {
    position: relative;
    justify-content: space-between;
    gap: 26px;
    padding: 34px clamp(24px, 4vw, 58px) 42px;
  }

  .neatpet-newsletter h2,
  .neatpet-newsletter p {
    margin: 0;
  }

  .neatpet-newsletter h2 {
    font-size: 1.55rem;
    letter-spacing: 0;
  }

  .neatpet-newsletter p {
    margin-top: 8px;
    color: #646760;
  }

  .neatpet-signup {
    display: flex;
    flex: 1 1 440px;
    max-width: 560px;
  }

  .neatpet-signup input {
    flex: 1;
    min-width: 0;
    height: 54px;
    border: 2px solid #deded8;
    border-right: 0;
    border-radius: 8px 0 0 8px;
    padding: 0 18px;
    font: inherit;
  }

  .neatpet-signup button {
    height: 54px;
    border: 0;
    border-radius: 0 8px 8px 0;
    padding: 0 26px;
    background: var(--np-green);
    color: #fff;
    font: inherit;
    font-weight: 800;
  }

  .neatpet-social {
    display: flex;
    gap: 18px;
    color: var(--np-green);
    font-weight: 900;
    font-size: 1.25rem;
  }

  .neatpet-paw {
    position: absolute;
    right: 26px;
    bottom: 20px;
    width: 138px;
    height: 112px;
    opacity: .42;
    pointer-events: none;
    background:
      radial-gradient(ellipse at 34% 68%, var(--np-green) 0 24%, transparent 25%),
      radial-gradient(ellipse at 18% 28%, var(--np-green) 0 12%, transparent 13%),
      radial-gradient(ellipse at 42% 18%, var(--np-green) 0 13%, transparent 14%),
      radial-gradient(ellipse at 72% 28%, var(--np-green) 0 12%, transparent 13%),
      radial-gradient(ellipse at 83% 62%, var(--np-green) 0 12%, transparent 13%);
  }

  @media screen and (max-width: 1080px) {
    .neatpet-hero,
    .neatpet-story {
      grid-template-columns: 1fr;
    }

    .neatpet-hero__scene {
      min-height: 470px;
    }

    .neatpet-benefits,
    .neatpet-category-grid,
    .neatpet-product-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .neatpet-service-row,
    .neatpet-newsletter {
      flex-wrap: wrap;
    }
  }

  @media screen and (max-width: 640px) {
    .neatpet-hero {
      min-height: auto;
    }

    .neatpet-hero__copy {
      padding: 42px 20px;
    }

    .neatpet-hero__actions,
    .neatpet-signup {
      flex-direction: column;
      align-items: stretch;
    }

    .neatpet-button,
    .neatpet-signup button,
    .neatpet-signup input {
      width: 100%;
      border-radius: 8px;
    }

    .neatpet-signup input {
      border-right: 2px solid #deded8;
    }

    .neatpet-benefits,
    .neatpet-category-grid,
    .neatpet-product-grid {
      grid-template-columns: 1fr;
      gap: 20px;
      padding-inline: 20px;
    }

    .neatpet-hero__scene {
      min-height: 360px;
    }

    .neatpet-pet--dog {
      right: 18%;
      width: 190px;
      height: 235px;
    }

    .neatpet-pet--cat {
      left: 6%;
      width: 130px;
      height: 160px;
    }

    .neatpet-product--spray,
    .neatpet-product--jar {
      display: none;
    }

    .neatpet-story,
    .neatpet-section-heading,
    .neatpet-service-row,
    .neatpet-newsletter {
      margin-inline: 20px;
      padding-inline: 0;
    }

    .neatpet-section-heading {
      margin-inline: 0;
      padding-inline: 20px;
    }

    .neatpet-service-row {
      display: grid;
      grid-template-columns: 1fr;
    }

    .neatpet-social,
    .neatpet-paw {
      display: none;
    }
  }
{% endstylesheet %}

