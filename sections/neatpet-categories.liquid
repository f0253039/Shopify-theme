<section class="np-categories color-{{ section.settings.color_scheme }}">
  <div class="np-categories__heading">
    {% if section.settings.heading != blank %}
      <h2>{{ section.settings.heading | escape }}</h2>
    {% endif %}
    {% if section.settings.link_label != blank %}
      <a href="{{ section.settings.link | default: '/collections' }}">{{ section.settings.link_label | escape }}</a>
    {% endif %}
  </div>

  <div class="np-categories__grid">
    {% for block in section.blocks %}
      <a class="np-categories__card" href="{{ block.settings.link | default: '/collections' }}" {{ block.shopify_attributes }}>
        {% if block.settings.image != blank %}
          {{
            block.settings.image
            | image_url: width: 560
            | image_tag: loading: 'lazy', widths: '280, 420, 560', sizes: '(min-width: 990px) 18vw, 90vw'
          }}
        {% else %}
          <span class="np-categories__visual np-categories__visual--{{ block.settings.visual_style }}"></span>
        {% endif %}
        {% if block.settings.title != blank %}
          <strong>{{ block.settings.title | escape }}</strong>
        {% endif %}
        {% if block.settings.text != blank %}
          <em>{{ block.settings.text | escape }}</em>
        {% endif %}
      </a>
    {% endfor %}
  </div>
</section>

{% stylesheet %}
  .np-categories {
    --np-green: #5f734f;
    --np-soft: #f7f6f1;
    color: #202420;
    background: #fff;
  }

  .np-categories__heading,
  .np-categories__grid {
    width: min(100%, 1500px);
    margin-inline: auto;
  }

  .np-categories__heading {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
    padding: 36px clamp(24px, 4vw, 58px) 20px;
  }

  .np-categories h2 {
    margin: 0;
    font-size: clamp(1.55rem, 2vw, 2rem);
    letter-spacing: 0;
  }

  .np-categories__heading a {
    color: var(--np-green);
    font-weight: 800;
    text-decoration: none;
  }

  .np-categories__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(170px, 1fr));
    gap: 28px;
    padding-inline: clamp(24px, 4vw, 58px);
  }

  .np-categories__card {
    min-width: 0;
    color: #2b302a;
    text-align: center;
    text-decoration: none;
  }

  .np-categories__card img,
  .np-categories__visual {
    display: block;
    width: 100%;
    aspect-ratio: 1;
    border-radius: 8px;
    background: var(--np-soft);
    overflow: hidden;
    object-fit: cover;
    box-shadow: inset 0 0 0 1px #efede7, 0 10px 22px rgb(54 46 36 / 6%);
  }

  .np-categories strong,
  .np-categories em {
    display: block;
  }

  .np-categories strong {
    margin-top: 15px;
    font-size: 1.06rem;
  }

  .np-categories em {
    margin-top: 5px;
    color: #60665e;
    font-size: .92rem;
    font-style: normal;
  }

  .np-categories__visual {
    position: relative;
  }

  .np-categories__visual::before,
  .np-categories__visual::after {
    content: "";
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
  }

  .np-categories__visual--roller::before {
    width: 56%;
    height: 28%;
    border: 2px solid #cbc3b8;
    border-radius: 999px;
    background: linear-gradient(#fff, #e0d9cf);
  }

  .np-categories__visual--spray::before,
  .np-categories__visual--home::before {
    width: 31%;
    height: 62%;
    border: 2px solid #d1c9bd;
    border-radius: 12px;
    background: linear-gradient(#fff 0 18%, #d9e4dc 19% 36%, #efe8dc 37%);
  }

  .np-categories__visual--wipes::before {
    width: 60%;
    height: 40%;
    border: 2px solid #e0d9ce;
    border-radius: 10px;
    background: linear-gradient(90deg, #c8dfcf 0 18%, #f6efe2 19% 81%, #c8dfcf 82%);
  }

  .np-categories__visual--bundle::before {
    width: 60%;
    height: 58%;
    background:
      linear-gradient(90deg, #f7f3eb 0 28%, transparent 29%),
      linear-gradient(90deg, transparent 34%, #dae5dc 35% 58%, transparent 59%),
      linear-gradient(90deg, transparent 63%, #efe6d9 64% 100%);
  }

  @media screen and (max-width: 1080px) {
    .np-categories__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media screen and (max-width: 640px) {
    .np-categories__heading {
      padding-inline: 20px;
    }

    .np-categories__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 20px;
      padding-inline: 20px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "NeatPet categories",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop by Category"
    },
    {
      "type": "text",
      "id": "link_label",
      "label": "Link label",
      "default": "View All"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link"
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "select",
          "id": "visual_style",
          "label": "Fallback visual",
          "options": [
            { "value": "roller", "label": "Roller" },
            { "value": "spray", "label": "Spray" },
            { "value": "wipes", "label": "Wipes" },
            { "value": "home", "label": "Home" },
            { "value": "bundle", "label": "Bundle" }
          ],
          "default": "roller"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Cleaning Tools"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Keep fur and mess away"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "NeatPet categories",
      "blocks": [
        { "type": "category", "settings": { "visual_style": "roller", "title": "Cleaning Tools", "text": "Keep fur and mess away" } },
        { "type": "category", "settings": { "visual_style": "spray", "title": "Odor Control", "text": "Eliminate bad smells" } },
        { "type": "category", "settings": { "visual_style": "wipes", "title": "Surface Cleaning", "text": "Clean every corner" } },
        { "type": "category", "settings": { "visual_style": "home", "title": "Home Care", "text": "Daily care for a tidy home" } },
        { "type": "category", "settings": { "visual_style": "bundle", "title": "Bundles", "text": "More care, more value" } }
      ]
    }
  ]
}
{% endschema %}
