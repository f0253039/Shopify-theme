    "product_highlights_pet": {
      "type": "product-list",
      "name": "Product highlights",
      "blocks": {
        "static-header": {
          "type": "_product-list-content",
          "name": "Header",
          "static": true,
          "settings": {
            "content_direction": "row",
            "vertical_on_mobile": true,
            "horizontal_alignment": "space-between",
            "vertical_alignment": "flex-end",
            "gap": 18,
            "width": "fill"
