{
  "sections": {
    "hero_pet_premium": {
      "type": "hero",
      "name": "Hero",
      "blocks": {
        "hero_content": {
          "type": "group",
          "name": "Hero content",
          "settings": {
            "content_direction": "column",
            "horizontal_alignment_flex_direction_column": "flex-start",
            "vertical_alignment_flex_direction_column": "center",
            "gap": 18,
            "width": "custom",
            "custom_width": 56,
            "width_mobile": "fill"
          },
          "blocks": {
            "eyebrow": {
              "type": "text",
              "name": "Eyebrow",
              "settings": {
                "text": "<p>Premium pet essentials, delivered</p>",
                "type_preset": "custom",
                "font": "var(--font-subheading--family)",
                "font_size": "0.875rem",
                "case": "uppercase"
              }
            },
            "headline": {
              "type": "text",
              "name": "Headline",
              "settings": {
                "text": "<h1>Smarter everyday care for pets and their people.</h1>",
                "width": "100%",
                "max_width": "normal",
                "type_preset": "custom",
                "font": "var(--font-heading--family)",
                "font_size": "4.5rem",
                "line_height": "tight",
                "wrap": "balance"
              }
            },
            "subheading": {
              "type": "text",
              "name": "Subheading",
              "settings": {
                "text": "<p>Curated toys, grooming tools, travel gear, feeders, and home comforts selected for cleaner routines, happier walks, and better rest.</p>",
                "width": "100%",
                "max_width": "narrow",
                "type_preset": "custom",
                "font": "var(--font-body--family)",
                "font_size": "1.25rem",
                "line_height": "loose",
                "wrap": "pretty",
                "padding-block-end": 8
              }
            },
            "cta": {
              "type": "button",
              "name": "Primary CTA",
              "settings": {
                "label": "Shop best sellers",
                "link": "shopify://collections/all",
                "style_class": "button",
                "width_mobile": "custom",
                "custom_width_mobile": 100
              }
            }
          },
          "block_order": ["eyebrow", "headline", "subheading", "cta"]
        }
      },
      "block_order": ["hero_content"],
      "settings": {
        "media_type_1": "image",
        "image_1": "shopify://shop_images/animals-pet-supplies-bold-4.jpg",
        "media_type_2": "image",
        "content_direction": "column",
        "horizontal_alignment_flex_direction_column": "flex-start",
        "vertical_alignment_flex_direction_column": "center",
        "section_width": "page-width",
        "section_height": "large",
        "color_scheme": "scheme-2",
        "toggle_overlay": true,
        "overlay_color": "#0202028a",
        "overlay_style": "gradient",
        "gradient_direction": "to bottom",
        "padding-block-start": 84,
        "padding-block-end": 88
      }
    },
