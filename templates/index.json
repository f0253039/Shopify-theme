            "heading": {
              "type": "_product-list-text",
              "name": "Heading",
              "settings": {
                "text": "<h2>Everyday upgrades worth adding to cart.</h2><p>A tight collection of best-fit essentials for grooming, play, walks, travel, feeding, and rest.</p>",
                "width": "100%",
                "max_width": "narrow",
                "type_preset": "rte"
              }
            },
            "button": {
              "type": "button",
              "name": "View all",
              "settings": {
                "label": "View all products",
                "link": "shopify://collections/all",
                "style_class": "button-secondary",
                "width_mobile": "custom",
                "custom_width_mobile": 100
              }
            }
          },
          "block_order": ["heading", "button"]
        },
        "static-product-card": {
          "type": "_product-card",
          "name": "Product card",
          "static": true,
          "settings": {
            "product_card_gap": 12
          },
          "blocks": {
            "media": {
              "type": "_product-card-gallery",
              "name": "Media",
              "settings": {
                "image_ratio": "square",
                "border_radius": 8
              }
            },
            "content": {
              "type": "_product-card-group",
              "name": "Content",
              "settings": {
                "content_direction": "column",
                "gap": 6,
                "width": "fill",
                "padding-block-start": 10
              },
              "blocks": {
                "title": {
                  "type": "text",
                  "settings": {
                    "text": "<h3>{{ closest.product.title }}</h3>",
                    "width": "100%",
                    "type_preset": "custom",
                    "font": "var(--font-body--family)",
                    "font_size": "1.125rem"
                  }
                },
                "price": {
                  "type": "price",
                  "settings": {
                    "show_sale_price_first": true,
                    "width": "100%",
                    "alignment": "left"
                  }
                },
                "swatches": {
                  "type": "swatches",
                  "settings": {
                    "product_swatches_alignment": "flex-start",
                    "product_swatches_alignment_mobile": "flex-start"
                  }
                }
              },
              "block_order": ["title", "price", "swatches"]
            }
          },
          "block_order": ["media", "content"]
        }
      },
      "settings": {
        "collection": "animals-and-pet-supplies-example-products",
        "layout_type": "grid",
        "carousel_on_mobile": false,
        "max_products": 8,
        "columns": 4,
